# Copy this file to .env and fill in values
# .env is gitignored — never commit real credentials

# PostgreSQL
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mortgage_rag

# LangFuse self-hosted
LANGFUSE_NEXTAUTH_SECRET=change-me-32-char-random-string
LANGFUSE_SALT=change-me-32-char-random-string
LANGFUSE_INIT_USER_PASSWORD=change-me
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-mortgage-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-mortgage-local

# For cloud deployment (free tier / Azure) — leave blank for local Docker
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
GROQ_API_KEY=
QDRANT_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
